{
  "name": "madarsa-backend-server",
  "version": "1.0.0",
  "description": "Backend server for Madarsa Management System",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "postinstall": "prisma generate",
    "seed": "node scripts/seed.js",
    "seed:permissions": "node scripts/seed-permissions.js",
    "tenant:default": "node scripts/ensure-default-tenant.js",
    "test:tenants": "node scripts/test-two-tenants.js",
    "test:roles": "node scripts/test-role-crud.js",
    "test:permissions": "node scripts/test-permissions-api.js",
    "test:users": "node scripts/test-user-crud.js",
    "test:authz": "node scripts/test-authorization-middleware.js",
    "test:branch-edges": "node scripts/test-branch-edge-cases.js",
    "test:branch-security": "node scripts/test-branch-security-suite.js",
    "test:finance-reconciliation": "node scripts/test-financial-branch-reconciliation.js",
    "test:branch-performance": "node scripts/test-branch-performance-audit.js",
    "test:branch-api-errors": "node scripts/test-branch-api-errors.js",
    "test:login-rbac": "node scripts/test-login-rbac-response.js",
    "test:audit-logs": "node scripts/test-rbac-audit-logs.js",
