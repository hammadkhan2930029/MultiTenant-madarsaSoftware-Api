  sabqRuku             String?  @db.VarChar(100)
  sabqAyatFrom         String?  @db.VarChar(100)
  sabqAyatTo           String?  @db.VarChar(100)
  sabqTeacherName      String?  @db.VarChar(150)
  sabqMistake          Int?
  sabqAtkann           Int?
  sabaqi               String?  @db.VarChar(150)
  sabaqiRuku           String?  @db.VarChar(100)
  sabaqiAyatFrom       String?  @db.VarChar(100)
  sabaqiAyatTo         String?  @db.VarChar(100)
  sabaqiMistake        Int?
  sabaqiAtkann         Int?
  manzil               String?  @db.VarChar(150)
  manzilBeforeDetail   String?  @db.VarChar(150)
  manzilBeforePara     String?  @db.VarChar(100)
  manzilBeforeRuku     String?  @db.VarChar(100)
  manzilBeforeAyatFrom String?  @db.VarChar(100)
  manzilBeforeAyatTo   String?  @db.VarChar(100)
  manzilBeforeMistake  Int?
  manzilBeforeAtkann   Int?
  manzilAfterDetail    String?  @db.VarChar(150)
  manzilAfterPara      String?  @db.VarChar(100)
  manzilAfterRuku      String?  @db.VarChar(100)
  manzilAfterAyatFrom  String?  @db.VarChar(100)
  manzilAfterAyatTo    String?  @db.VarChar(100)
  manzilAfterMistake   Int?
  manzilAfterAtkann    Int?
  lessonDetail         String?  @db.VarChar(255)
  count                Int?
