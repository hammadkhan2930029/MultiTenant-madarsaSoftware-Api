  @@index([tenantId])
  @@map("hifz_sipara_entries")
}

model FinanceHead {
  id            Int                  @id @default(autoincrement())
  tenantId      Int                  @map("tenant_id")
  name          String               @db.VarChar(150)
  type          String               @db.VarChar(20)
  description   String?              @db.VarChar(255)
  status        String               @default("active") @db.VarChar(50)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  tenant        Tenant               @relation("TenantFinanceHeads", fields: [tenantId], references: [id])
  salaryEntries SalaryEntry[]
  transactions  FinanceTransaction[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("finance_heads")
}

model StudentFeeVoucher {
  id            Int       @id @default(autoincrement())
  tenantId      Int       @map("tenant_id")
  voucherNo     String    @db.VarChar(100)
  studentId     Int
  feeMonth      Int
  feeYear       Int
  monthlyFee    Decimal   @db.Decimal(10, 2)
  admissionFee  Decimal   @default(0) @db.Decimal(10, 2)
  arrears       Decimal   @default(0) @db.Decimal(10, 2)
  discount      Decimal   @default(0) @db.Decimal(10, 2)
  fine          Decimal   @default(0) @db.Decimal(10, 2)
  totalAmount   Decimal   @db.Decimal(10, 2)
  paidAmount    Decimal   @default(0) @db.Decimal(10, 2)
  dueAmount     Decimal   @db.Decimal(10, 2)
  dueDate       DateTime?
  paidDate      DateTime?
  paymentMethod String?   @db.VarChar(50)
  remarks       String?   @db.VarChar(255)
  status        String    @default("unpaid") @db.VarChar(50)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  tenant        Tenant    @relation("TenantFeeVouchers", fields: [tenantId], references: [id])
  student       Student   @relation(fields: [studentId], references: [id])

  @@unique([tenantId, voucherNo])
  @@unique([studentId, feeMonth, feeYear])
  @@index([tenantId])
  @@index([tenantId, status, paidDate])
  @@index([tenantId, status, dueDate])
  @@index([tenantId, feeMonth, feeYear, status])
  @@index([feeMonth, feeYear, status])
  @@map("student_fee_vouchers")
}

model FundCollection {
  id                Int      @id @default(autoincrement())
  tenantId          Int      @map("tenant_id")
  branchId          Int?     @map("branch_id")
  collectionGroupId String   @db.VarChar(100)
  donorName         String   @db.VarChar(150)
  careOf            String?  @db.VarChar(150)
  phone             String?  @db.VarChar(50)
  paymentMode       String   @db.VarChar(50)
  donationType      String   @db.VarChar(100)
  donationSubType   String   @db.VarChar(100)
  purpose           String?  @db.VarChar(255)
  amount            Decimal  @db.Decimal(10, 2)
  receiptNo         String?  @db.VarChar(100)
  details           String?  @db.VarChar(255)
  paymentDate       DateTime
  remarks           String?  @db.VarChar(255)
  status            String   @default("active") @db.VarChar(50)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  tenant            Tenant   @relation("TenantFundCollections", fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([branchId])
  @@index([tenantId, branchId])
  @@index([tenantId, branchId, status, paymentDate])
  @@index([collectionGroupId])
  @@map("fund_collections")
}

model SalaryEntry {
  id            Int         @id @default(autoincrement())
  tenantId      Int         @map("tenant_id")
  branchId      Int?        @map("branch_id")
  teacherId     Int
  financeHeadId Int
  amount        Decimal     @db.Decimal(10, 2)
  salaryMonth   Int
  salaryYear    Int
  paymentDate   DateTime
  remarks       String?     @db.VarChar(255)
  status        String      @default("active") @db.VarChar(50)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  tenant        Tenant      @relation("TenantSalaryEntries", fields: [tenantId], references: [id])
  teacher       Teacher     @relation(fields: [teacherId], references: [id])
  financeHead   FinanceHead @relation(fields: [financeHeadId], references: [id])

  @@unique([teacherId, salaryMonth, salaryYear])
  @@index([tenantId])
  @@index([branchId])
  @@index([tenantId, branchId])
  @@index([tenantId, branchId, status, paymentDate])
  @@index([tenantId, branchId, teacherId, salaryMonth, salaryYear])
  @@map("salary_entries")
}

model FinanceTransaction {
  id              Int         @id @default(autoincrement())
  tenantId        Int         @map("tenant_id")
  branchId        Int?        @map("branch_id")
  financeHeadId   Int
  type            String      @db.VarChar(20)
  amount          Decimal     @db.Decimal(10, 2)
  transactionDate DateTime
  paymentMode     String?     @db.VarChar(50)
  paymentStatus   String?     @db.VarChar(50)
  slipNo          String?     @db.VarChar(100)
  details         String?     @db.VarChar(255)
  referenceType   String?     @db.VarChar(50)
  referenceId     Int?
  status          String      @default("active") @db.VarChar(50)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  tenant          Tenant      @relation("TenantFinanceTransactions", fields: [tenantId], references: [id])
  financeHead     FinanceHead @relation(fields: [financeHeadId], references: [id])

  @@unique([tenantId, referenceType, referenceId])
  @@index([tenantId])
  @@index([branchId])
  @@index([tenantId, branchId])
  @@index([tenantId, branchId, status, transactionDate])
  @@index([tenantId, branchId, type, transactionDate])
  @@index([type, transactionDate])
  @@index([financeHeadId])
  @@map("finance_transactions")
}

model FinancialRecord {
  id          Int      @id @default(autoincrement())
  tenantId    Int      @map("tenant_id")
  branchId    Int?     @map("branch_id")
  type        String   @db.VarChar(20)
  category    String   @db.VarChar(150)
  description String?  @db.VarChar(255)
  amount      Decimal  @db.Decimal(10, 2)
  date        DateTime
  status      String   @default("active") @db.VarChar(50)
  createdById Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation("TenantFinancialRecords", fields: [tenantId], references: [id])
  createdBy   Admin?   @relation(fields: [createdById], references: [id])

  @@index([tenantId])
  @@index([branchId])
  @@index([tenantId, branchId])
  @@index([tenantId, branchId, status, date])
  @@index([tenantId, branchId, type, date, status])
  @@index([type, date, status])
  @@index([createdById])
  @@map("financial_records")
}

model StoreItem {
  id               Int                    @id @default(autoincrement())
  tenantId         Int                    @map("tenant_id")
  itemName         String                 @db.VarChar(150)
  category         String                 @db.VarChar(150)
  description      String?                @db.VarChar(255)
  unit             String                 @db.VarChar(50)
  itemCode         String                 @db.VarChar(100)
  currentStock     Decimal                @default(0) @db.Decimal(10, 2)
  purchasePrice    Decimal                @default(0) @db.Decimal(10, 2)
  status           String                 @default("active") @db.VarChar(50)
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  tenant           Tenant                 @relation("TenantStoreItems", fields: [tenantId], references: [id])
  purchaseItems    StorePurchaseItem[]
  stockIssues      StoreStockIssue[]
  returns          StoreReturn[]
  damagedStocks    StoreDamagedStock[]
  stockAdjustments StoreStockAdjustment[]

  @@unique([tenantId, itemCode], map: "store_items_tenant_item_code_uq")
  @@index([tenantId])
  @@index([category])
  @@index([status])
  @@map("store_items")
}

model StoreUnit {
  id          Int      @id @default(autoincrement())
  tenantId    Int      @map("tenant_id")
  name        String   @db.VarChar(150)
  shortName   String   @db.VarChar(50)
  description String?  @db.VarChar(255)
  status      String   @default("active") @db.VarChar(50)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation("TenantStoreUnits", fields: [tenantId], references: [id])

  @@unique([tenantId, shortName], map: "store_units_tenant_short_name_uq")
  @@index([tenantId])
  @@index([status])
  @@map("store_units")
}

model StoreCategory {
  id          Int      @id @default(autoincrement())
  tenantId    Int      @map("tenant_id")
  name        String   @db.VarChar(150)
  description String?  @db.VarChar(255)
  status      String   @default("active") @db.VarChar(50)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation("TenantStoreCategories", fields: [tenantId], references: [id])

  @@unique([tenantId, name], map: "store_categories_tenant_name_uq")
  @@index([tenantId])
  @@index([status])
  @@map("store_categories")
}

model StoreSupplier {
  id           Int                    @id @default(autoincrement())
  tenantId     Int                    @map("tenant_id")
  supplierName String                 @db.VarChar(150)
  mobileNumber String?                @db.VarChar(50)
  address      String?                @db.VarChar(255)
  shopName     String?                @db.VarChar(150)
  balance      Decimal                @default(0) @db.Decimal(10, 2)
  status       String                 @default("active") @db.VarChar(50)
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  tenant       Tenant                 @relation("TenantStoreSuppliers", fields: [tenantId], references: [id])
  purchases    StorePurchase[]
  payments     StoreSupplierPayment[]

  @@unique([tenantId, supplierName], map: "store_suppliers_tenant_name_uq")
  @@index([tenantId])
  @@index([status])
  @@map("store_suppliers")
}

model StoreSupplierPayment {
  id            Int           @id @default(autoincrement())
  tenantId      Int           @map("tenant_id")
  branchId      Int?          @map("branch_id")
  supplierId    Int
  amount        Decimal       @db.Decimal(10, 2)
  paymentDate   DateTime
  paymentMethod String?       @db.VarChar(50)
  note          String?       @db.VarChar(255)
  status        String        @default("active") @db.VarChar(50)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  tenant        Tenant        @relation("TenantStoreSupplierPayments", fields: [tenantId], references: [id])
  supplier      StoreSupplier @relation(fields: [supplierId], references: [id])

  @@index([tenantId])
  @@index([branchId])
  @@index([tenantId, branchId])
  @@index([tenantId, branchId, status, paymentDate])
  @@index([tenantId, branchId, supplierId, paymentDate])
  @@index([supplierId])
  @@index([paymentDate, status])
  @@map("store_supplier_payments")
}

model StorePurchase {
  id                   Int                 @id @default(autoincrement())
  tenantId             Int                 @map("tenant_id")
  branchId             Int?                @map("branch_id")
  purchaseDate         DateTime
  supplierId           Int
  invoiceNumber        String?             @db.VarChar(100)
  totalAmount          Decimal             @default(0) @db.Decimal(10, 2)
  paidAmount           Decimal             @default(0) @db.Decimal(10, 2)
  remainingAmount      Decimal             @default(0) @db.Decimal(10, 2)
  paymentMethod        String?             @db.VarChar(50)
  invoiceImage         String?             @db.VarChar(255)
  approvalStatus       String              @default("approved") @db.VarChar(50)
  financeTransactionId Int?
  status               String              @default("active") @db.VarChar(50)
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  tenant               Tenant              @relation("TenantStorePurchases", fields: [tenantId], references: [id])
  supplier             StoreSupplier       @relation(fields: [supplierId], references: [id])
  items                StorePurchaseItem[]

  @@index([tenantId])
  @@index([branchId])
  @@index([tenantId, branchId])
  @@index([tenantId, branchId, status, purchaseDate])
  @@index([tenantId, branchId, approvalStatus, purchaseDate])
  @@index([tenantId, branchId, supplierId, purchaseDate])
  @@index([purchaseDate, status])
  @@index([supplierId])
  @@index([financeTransactionId])
  @@map("store_purchases")
}

model StorePurchaseItem {
  id         Int           @id @default(autoincrement())
  tenantId   Int           @map("tenant_id")
  branchId   Int?          @map("branch_id")
  purchaseId Int
  itemId     Int
  unitId     Int?
  quantity   Decimal       @db.Decimal(10, 2)
  rate       Decimal       @db.Decimal(10, 2)
  total      Decimal       @db.Decimal(10, 2)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  tenant     Tenant        @relation("TenantStorePurchaseItems", fields: [tenantId], references: [id])
  purchase   StorePurchase @relation(fields: [purchaseId], references: [id])
  item       StoreItem     @relation(fields: [itemId], references: [id])

  @@index([tenantId])
  @@index([branchId])
  @@index([tenantId, branchId])
  @@index([tenantId, branchId, itemId])
  @@index([tenantId, branchId, purchaseId])
  @@index([purchaseId])
  @@index([itemId])
  @@index([unitId])
  @@map("store_purchase_items")
}

model StoreStockIssue {
  id                Int           @id @default(autoincrement())
  tenantId          Int           @map("tenant_id")
  branchId          Int?          @map("branch_id")
  issueDate         DateTime
  itemId            Int
  quantity          Decimal       @db.Decimal(10, 2)
  returnedQuantity  Decimal       @default(0) @db.Decimal(10, 2)
  department        String        @db.VarChar(150)
  receiverName      String        @db.VarChar(150)
  purpose           String?       @db.VarChar(255)
  issuedBy          String        @db.VarChar(150)
  receiverSignature String?       @db.VarChar(255)
  approvalStatus    String        @default("approved") @db.VarChar(50)
  status            String        @default("active") @db.VarChar(50)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  tenant            Tenant        @relation("TenantStoreStockIssues", fields: [tenantId], references: [id])
  item              StoreItem     @relation(fields: [itemId], references: [id])
  returns           StoreReturn[]

  @@index([tenantId])
  @@index([branchId])
  @@index([tenantId, branchId])
  @@index([tenantId, branchId, status, issueDate])
  @@index([tenantId, branchId, approvalStatus, issueDate])
  @@index([tenantId, branchId, itemId, issueDate])
  @@index([itemId])
  @@index([issueDate, status])
  @@index([approvalStatus])
  @@map("store_stock_issues")
}

model StoreReturn {
  id             Int             @id @default(autoincrement())
  tenantId       Int             @map("tenant_id")
  branchId       Int?            @map("branch_id")
  stockIssueId   Int
  itemId         Int
  returnQuantity Decimal         @db.Decimal(10, 2)
  condition      String          @db.VarChar(50)
  addToStock     Boolean         @default(true)
  note           String?         @db.VarChar(255)
  status         String          @default("active") @db.VarChar(50)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  tenant         Tenant          @relation("TenantStoreReturns", fields: [tenantId], references: [id])
  stockIssue     StoreStockIssue @relation(fields: [stockIssueId], references: [id])
  item           StoreItem       @relation(fields: [itemId], references: [id])

  @@index([tenantId])
  @@index([branchId])
  @@index([tenantId, branchId])
  @@index([tenantId, branchId, status, createdAt])
  @@index([tenantId, branchId, itemId, createdAt])
  @@index([stockIssueId])
  @@index([itemId])
  @@map("store_returns")
}

model StoreDamagedStock {
  id                Int       @id @default(autoincrement())
  tenantId          Int       @map("tenant_id")
  branchId          Int?      @map("branch_id")
  returnId          Int?
  itemId            Int
  quantity          Decimal   @db.Decimal(10, 2)
  reason            String?   @db.VarChar(255)
  date              DateTime  @default(now())
  responsiblePerson String?   @db.VarChar(150)
  amountLoss        Decimal   @default(0) @db.Decimal(10, 2)
  approvalStatus    String    @default("approved") @db.VarChar(50)
  note              String?   @db.VarChar(255)
  status            String    @default("active") @db.VarChar(50)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  tenant            Tenant    @relation("TenantStoreDamagedStocks", fields: [tenantId], references: [id])
  item              StoreItem @relation(fields: [itemId], references: [id])

  @@index([tenantId])
  @@index([branchId])
  @@index([tenantId, branchId])
  @@index([tenantId, branchId, status, date])
  @@index([tenantId, branchId, approvalStatus, date])
  @@index([tenantId, branchId, itemId, date])
  @@index([returnId])
  @@index([itemId])
  @@index([date, status])
  @@index([approvalStatus])
  @@map("store_damaged_stock")
}

model StoreApprovalLog {
  id         Int      @id @default(autoincrement())
  tenantId   Int      @map("tenant_id")
  branchId   Int?     @map("branch_id")
  moduleType String   @db.VarChar(50)
  recordId   Int
  status     String   @db.VarChar(50)
  approvedBy String?  @db.VarChar(150)
  remarks    String?  @db.VarChar(255)
  createdAt  DateTime @default(now())
  tenant     Tenant   @relation("TenantStoreApprovalLogs", fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([branchId])
  @@index([tenantId, branchId])
  @@index([moduleType, recordId])
  @@index([status])
  @@map("store_approval_logs")
}

model StoreStockAdjustment {
  id             Int       @id @default(autoincrement())
  tenantId       Int       @map("tenant_id")
  branchId       Int?      @map("branch_id")
  itemId         Int
  adjustmentType String    @db.VarChar(20)
  quantity       Decimal   @db.Decimal(10, 2)
  previousStock  Decimal   @default(0) @db.Decimal(10, 2)
  adjustedStock  Decimal   @default(0) @db.Decimal(10, 2)
  reason         String?   @db.VarChar(255)
  approvalStatus String    @default("pending") @db.VarChar(50)
  status         String    @default("active") @db.VarChar(50)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  tenant         Tenant    @relation("TenantStoreStockAdjustments", fields: [tenantId], references: [id])
  item           StoreItem @relation(fields: [itemId], references: [id])

  @@index([tenantId])
  @@index([branchId])
  @@index([tenantId, branchId])
  @@index([tenantId, branchId, itemId])
  @@index([tenantId, branchId, approvalStatus])
  @@index([itemId])
  @@index([approvalStatus])
  @@index([status])
  @@map("store_stock_adjustments")
}
