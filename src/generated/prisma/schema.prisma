generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/prisma"
  binaryTargets = ["native", "debian-openssl-1.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id                  Int                      @id @default(autoincrement())
  tenantCode          String                   @unique
  name                String
  subdomain           String?                  @unique
  customDomain        String?                  @unique
  status              String                   @default("active")
  branchEnabled       Boolean                  @default(false) @map("branch_enabled")
  branchLimit         Int?                     @map("branch_limit")
  ownerAdminId        Int?
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
  admins              Admin[]                  @relation("TenantAdmins")
  roles               Role[]                   @relation("TenantRoles")
  rolePermissions     RolePermission[]         @relation("TenantRolePermissions")
  profile             MadrassaProfile?         @relation("TenantMadrassaProfile")
  students            Student[]                @relation("TenantStudents")
  parents             Parent[]                 @relation("TenantParents")
  teachers            Teacher[]                @relation("TenantTeachers")
  branches            Branch[]                 @relation("TenantBranches")
  classes             AcademicClass[]          @relation("TenantClasses")
  sections            Section[]                @relation("TenantSections")
  assignments         StudentClassAssignment[] @relation("TenantClassAssignments")
  subjects            Subject[]                @relation("TenantSubjects")
  examSchedules       ExamSchedule[]           @relation("TenantExamSchedules")
  resultGrades        ResultGrade[]            @relation("TenantResultGrades")
  examResults         ExamResult[]             @relation("TenantExamResults")
  examResultSubjects  ExamResultSubject[]      @relation("TenantExamResultSubjects")
  financeHeads        FinanceHead[]            @relation("TenantFinanceHeads")
  feeVouchers         StudentFeeVoucher[]      @relation("TenantFeeVouchers")
  fundCollections     FundCollection[]         @relation("TenantFundCollections")
  salaryEntries       SalaryEntry[]            @relation("TenantSalaryEntries")
  financeTransactions FinanceTransaction[]     @relation("TenantFinanceTransactions")
  financialRecords    FinancialRecord[]        @relation("TenantFinancialRecords")
  storeItems          StoreItem[]              @relation("TenantStoreItems")
  storeUnits          StoreUnit[]              @relation("TenantStoreUnits")
  storeCategories     StoreCategory[]          @relation("TenantStoreCategories")
  storeSuppliers      StoreSupplier[]          @relation("TenantStoreSuppliers")
  storeSupplierPays   StoreSupplierPayment[]   @relation("TenantStoreSupplierPayments")
  storePurchases      StorePurchase[]          @relation("TenantStorePurchases")
  storePurchaseItems  StorePurchaseItem[]      @relation("TenantStorePurchaseItems")
  storeStockIssues    StoreStockIssue[]        @relation("TenantStoreStockIssues")
  storeReturns        StoreReturn[]            @relation("TenantStoreReturns")
  storeDamagedStocks  StoreDamagedStock[]      @relation("TenantStoreDamagedStocks")
  storeApprovalLogs   StoreApprovalLog[]       @relation("TenantStoreApprovalLogs")
  storeAdjustments    StoreStockAdjustment[]   @relation("TenantStoreStockAdjustments")
  hifzDailyEntries    HifzDailyEntry[]         @relation("TenantHifzDailyEntries")
  hifzWeeklyEntries   HifzWeeklyEntry[]        @relation("TenantHifzWeeklyEntries")
  hifzMonthlyEntries  HifzMonthlyEntry[]       @relation("TenantHifzMonthlyEntries")
  hifzSiparaEntries   HifzSiparaEntry[]        @relation("TenantHifzSiparaEntries")
  suggestions         Suggestion[]             @relation("TenantSuggestions")
  supportRequests     SupportRequest[]         @relation("TenantSupportRequests")
  studentSchedules    StudentSchedule[]        @relation("TenantStudentSchedules")
  teacherSchedules    TeacherSchedule[]        @relation("TenantTeacherSchedules")
  studentParents      StudentParent[]          @relation("TenantStudentParents")
  studentAttendances  StudentAttendance[]      @relation("TenantStudentAttendances")
  teacherAttendances  TeacherAttendance[]      @relation("TenantTeacherAttendances")
  salaryIncrements    TeacherSalaryIncrement[] @relation("TenantTeacherSalaryIncrements")

  @@map("tenant")
}

model Admin {
  id               Int                      @id @default(autoincrement())
  name             String                   @db.VarChar(150)
  email            String                   @db.VarChar(150)
  phone            String?                  @db.VarChar(50)
  username         String                   @db.VarChar(100)
  password         String                   @db.VarChar(255)
  role             String                   @default("admin") @db.VarChar(50)
  tenantId         Int?                     @map("tenant_id")
  roleId           Int?                     @map("role_id")
  ownerAdminId     Int?                     @map("owner_admin_id")
  branchId         Int?                     @map("branch_id")
  status           String                   @default("active") @db.VarChar(50)
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  tenant           Tenant?                  @relation("TenantAdmins", fields: [tenantId], references: [id], onDelete: SetNull)
  assignedRole     Role?                    @relation("AdminAssignedRole", fields: [roleId], references: [id], onDelete: SetNull)
  assignedBranch   Branch?                  @relation("AdminBranchAssignment", fields: [branchId], references: [id], onDelete: SetNull)
  ownerAdmin       Admin?                   @relation("AdminMadrassaOwner", fields: [ownerAdminId], references: [id], onDelete: SetNull)
  ownedUsers       Admin[]                  @relation("AdminMadrassaOwner")
  createdBranches  Branch[]                 @relation("BranchCreatedBy")
  createdRoles     Role[]                   @relation("RoleCreatedBy")
  updatedRoles     Role[]                   @relation("RoleUpdatedBy")
  madrassaProfile  MadrassaProfile?
  financialRecords FinancialRecord[]
  suggestions      Suggestion[]
  supportRequests  SupportRequest[]
  salaryIncrements TeacherSalaryIncrement[]
  auditLogs        AuditLog[]               @relation("AdminAuditLogs")

  @@unique([tenantId, email])
  @@unique([tenantId, username])
  @@index([tenantId])
  @@index([branchId])
  @@index([tenantId, branchId])
  @@index([roleId])
  @@index([ownerAdminId])
  @@map("admins")
}

model AuditLog {
  id          Int      @id @default(autoincrement())
  tenantId    Int?     @map("tenant_id")
  actorUserId Int?     @map("actor_user_id")
  branchId    Int?     @map("branch_id")
  roleId      Int?     @map("role_id")
  action      String   @db.VarChar(100)
  module      String   @db.VarChar(100)
  targetType  String   @map("target_type") @db.VarChar(100)
  targetId    Int?     @map("target_id")
  oldValue    Json?    @map("old_value")
  newValue    Json?    @map("new_value")
  ipAddress   String?  @map("ip_address") @db.VarChar(100)
  userAgent   String?  @map("user_agent") @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at")
  actor       Admin?   @relation("AdminAuditLogs", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([actorUserId])
  @@index([branchId])
  @@index([roleId])
  @@index([tenantId, branchId])
  @@index([module, action])
  @@index([targetType, targetId])
  @@index([createdAt])
  @@map("audit_logs")
}

model Role {
  id              Int              @id @default(autoincrement())
  tenantId        Int?             @map("tenant_id")
  roleName        String           @map("role_name") @db.VarChar(100)
  description     String?          @db.VarChar(255)
  status          String           @default("active") @db.VarChar(50)
  isSystemRole    Boolean          @default(false) @map("is_system_role")
  createdBy       Int?             @map("created_by")
  updatedBy       Int?             @map("updated_by")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  tenant          Tenant?          @relation("TenantRoles", fields: [tenantId], references: [id], onDelete: Cascade)
  creator         Admin?           @relation("RoleCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)
  updater         Admin?           @relation("RoleUpdatedBy", fields: [updatedBy], references: [id], onDelete: SetNull)
  admins          Admin[]          @relation("AdminAssignedRole")
  rolePermissions RolePermission[]

  @@unique([tenantId, roleName])
  @@index([tenantId])
  @@index([status])
  @@index([isSystemRole])
  @@index([createdBy])
  @@index([updatedBy])
  @@map("roles")
}

model Permission {
  id              Int              @id @default(autoincrement())
  permissionKey   String           @unique @map("permission_key") @db.VarChar(150)
  permissionName  String           @map("permission_name") @db.VarChar(150)
  displayLabel    String?          @map("display_label") @db.VarChar(150)
  description     String?          @db.VarChar(255)
  pagePath        String?          @map("page_path") @db.VarChar(255)
  moduleName      String           @map("module_name") @db.VarChar(100)
  action          String?          @db.VarChar(50)
  sortOrder       Int              @default(0) @map("sort_order")
  createdAt       DateTime         @default(now()) @map("created_at")
  rolePermissions RolePermission[]

  @@index([moduleName])
  @@index([moduleName, action])
  @@map("permissions")
}

model RolePermission {
  id           Int        @id @default(autoincrement())
  tenantId     Int?       @map("tenant_id")
  roleId       Int        @map("role_id")
  permissionId Int        @map("permission_id")
  createdAt    DateTime   @default(now()) @map("created_at")
  tenant       Tenant?    @relation("TenantRolePermissions", fields: [tenantId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([tenantId])
  @@index([permissionId])
  @@map("role_permissions")
}

model MadrassaProfile {
  id          Int      @id @default(autoincrement())
  adminId     Int      @unique
  tenantId    Int      @unique @map("tenant_id")
  name        String   @db.VarChar(150)
  email       String   @db.VarChar(150)
  phone1      String?  @db.VarChar(50)
  phone2      String?  @db.VarChar(50)
  address     String?  @db.VarChar(255)
  branch      String?  @db.VarChar(150)
  city        String?  @db.VarChar(150)
  familyNoSeq String?  @db.VarChar(100)
  regNo       String?  @db.VarChar(100)
  logoUrl     String?  @db.VarChar(255)
  status      String   @default("active") @db.VarChar(50)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  admin       Admin    @relation(fields: [adminId], references: [id])
  tenant      Tenant   @relation("TenantMadrassaProfile", fields: [tenantId], references: [id])

  @@map("madrassa_profiles")
}

/// Intentionally global master data shared by all tenants.
model City {
  id        Int      @id @default(autoincrement())
  name      String   @unique @db.VarChar(150)
  status    String   @default("active") @db.VarChar(50)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("cities")
}

model Suggestion {
  id             Int      @id @default(autoincrement())
  tenantId       Int      @map("tenant_id")
  branchId       Int?     @map("branch_id")
  type           String   @db.VarChar(100)
  title          String   @db.VarChar(180)
  priority       String   @default("normal") @db.VarChar(50)
  description    String   @db.Text
  submitterName  String?  @db.VarChar(150)
  submitterEmail String?  @db.VarChar(150)
  adminId        Int?
  emailRecipient String?  @db.VarChar(150)
  emailStatus    String   @default("pending") @db.VarChar(50)
  emailError     String?  @db.VarChar(500)
  status         String   @default("new") @db.VarChar(50)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  tenant         Tenant   @relation("TenantSuggestions", fields: [tenantId], references: [id])
  branch         Branch?  @relation("BranchSuggestions", fields: [branchId], references: [id], onDelete: SetNull)
  admin          Admin?   @relation(fields: [adminId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([branchId])
  @@index([status])
  @@index([priority])
  @@index([adminId])
  @@map("suggestions")
}

model SupportRequest {
  id             Int      @id @default(autoincrement())
  tenantId       Int      @map("tenant_id")
  branchId       Int?     @map("branch_id")
  topic          String   @db.VarChar(120)
  priority       String   @default("normal") @db.VarChar(50)
  message        String   @db.Text
  submitterName  String?  @db.VarChar(150)
  submitterEmail String?  @db.VarChar(150)
  adminId        Int?
  emailRecipient String?  @db.VarChar(150)
  emailStatus    String   @default("pending") @db.VarChar(50)
  emailError     String?  @db.VarChar(500)
  status         String   @default("open") @db.VarChar(50)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  tenant         Tenant   @relation("TenantSupportRequests", fields: [tenantId], references: [id])
  branch         Branch?  @relation("BranchSupportRequests", fields: [branchId], references: [id], onDelete: SetNull)
  admin          Admin?   @relation(fields: [adminId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([branchId])
  @@index([status])
  @@index([priority])
  @@index([adminId])
  @@map("support_requests")
}

/// Intentionally global master data shared by all tenants.
model Shift {
  id        Int       @id @default(autoincrement())
  name      String    @unique @db.VarChar(150)
  startTime String    @db.VarChar(10)
  endTime   String    @db.VarChar(10)
  type      String    @db.VarChar(50)
  status    String    @default("active") @db.VarChar(50)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  teachers  Teacher[]

  @@map("shifts")
}

/// Intentionally global master data shared by all tenants.
model Department {
  id        Int      @id @default(autoincrement())
  name      String   @unique @db.VarChar(150)
  code      String?  @unique @db.VarChar(50)
  head      String?  @db.VarChar(150)
  members   Int      @default(0)
  status    String   @default("active") @db.VarChar(50)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("departments")
}

/// Intentionally global master data shared by all tenants.
model Qualification {
  id        Int      @id @default(autoincrement())
  title     String   @unique @db.VarChar(150)
  category  String?  @db.VarChar(150)
  level     String?  @db.VarChar(150)
  status    String   @default("active") @db.VarChar(50)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("qualifications")
}

model Subject {
  id                 Int                 @id @default(autoincrement())
  tenantId           Int                 @map("tenant_id")
  name               String              @db.VarChar(150)
  detail             String?             @db.VarChar(255)
  status             String              @default("active") @db.VarChar(50)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  tenant             Tenant              @relation("TenantSubjects", fields: [tenantId], references: [id])
  examSchedules      ExamSchedule[]
  examResultSubjects ExamResultSubject[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("subjects")
}

model Branch {
  id                 Int                      @id @default(autoincrement())
  tenantId           Int                      @map("tenant_id")
  name               String                   @db.VarChar(150)
  code               String?                  @db.VarChar(50)
  address            String?                  @db.VarChar(255)
  contact            String?                  @db.VarChar(50)
  createdBy          Int?                     @map("created_by")
  status             String                   @default("active") @db.VarChar(50)
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  tenant             Tenant                   @relation("TenantBranches", fields: [tenantId], references: [id])
  creator            Admin?                   @relation("BranchCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)
  assignedAdmins     Admin[]                  @relation("AdminBranchAssignment")
  students           Student[]                @relation("BranchStudents")
  parents            Parent[]                 @relation("BranchParents")
  teachers           Teacher[]                @relation("BranchTeachers")
  classes            AcademicClass[]
  assignments        StudentClassAssignment[]
  studentAttendances StudentAttendance[]
  teacherAttendances TeacherAttendance[]
  suggestions        Suggestion[]             @relation("BranchSuggestions")
  supportRequests    SupportRequest[]         @relation("BranchSupportRequests")

  @@unique([tenantId, name])
  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([createdBy])
  @@map("branches")
}

model AcademicClass {
  id                 Int                      @id @default(autoincrement())
  tenantId           Int                      @map("tenant_id")
  name               String                   @db.VarChar(150)
  branchId           Int
  status             String                   @default("active") @db.VarChar(50)
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  tenant             Tenant                   @relation("TenantClasses", fields: [tenantId], references: [id])
  branch             Branch                   @relation(fields: [branchId], references: [id])
  sections           Section[]
  assignments        StudentClassAssignment[]
  studentAttendances StudentAttendance[]
  studentSchedules   StudentSchedule[]
  teacherSchedules   TeacherSchedule[]
  examSchedules      ExamSchedule[]
  examResults        ExamResult[]

  @@unique([branchId, name])
  @@index([tenantId])
  @@map("classes")
}

model Section {
  id                 Int                      @id @default(autoincrement())
  tenantId           Int                      @map("tenant_id")
  name               String                   @db.VarChar(150)
  classId            Int
  status             String                   @default("active") @db.VarChar(50)
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  tenant             Tenant                   @relation("TenantSections", fields: [tenantId], references: [id])
  class              AcademicClass            @relation(fields: [classId], references: [id])
  assignments        StudentClassAssignment[]
  studentAttendances StudentAttendance[]
  studentSchedules   StudentSchedule[]
  teacherSchedules   TeacherSchedule[]
  examResults        ExamResult[]

  @@unique([classId, name])
  @@index([tenantId])
  @@map("sections")
}

/// Intentionally global master data shared by all tenants.
model AcademicSession {
  id               Int                      @id @default(autoincrement())
  name             String                   @unique @db.VarChar(150)
  startDate        DateTime
  endDate          DateTime
  status           String                   @default("active") @db.VarChar(50)
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  assignments      StudentClassAssignment[]
  studentSchedules StudentSchedule[]
  teacherSchedules TeacherSchedule[]
  examSchedules    ExamSchedule[]
  examResults      ExamResult[]

  @@map("sessions")
}

model StudentSchedule {
  id        Int             @id @default(autoincrement())
  tenantId  Int             @map("tenant_id")
  sessionId Int
  classId   Int
  sectionId Int
  subjects  Json
  days      Json
  startTime String          @db.VarChar(10)
  endTime   String          @db.VarChar(10)
  status    String          @default("active") @db.VarChar(50)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  tenant    Tenant          @relation("TenantStudentSchedules", fields: [tenantId], references: [id])
  session   AcademicSession @relation(fields: [sessionId], references: [id])
  class     AcademicClass   @relation(fields: [classId], references: [id])
  section   Section         @relation(fields: [sectionId], references: [id])

  @@index([tenantId])
  @@index([sessionId, classId, sectionId])
  @@map("student_schedules")
}

model TeacherSchedule {
  id        Int             @id @default(autoincrement())
  tenantId  Int             @map("tenant_id")
  teacherId Int
  sessionId Int
  classId   Int
  sectionId Int
  subjects  Json
  days      Json
  startTime String          @db.VarChar(10)
  endTime   String          @db.VarChar(10)
  status    String          @default("active") @db.VarChar(50)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  tenant    Tenant          @relation("TenantTeacherSchedules", fields: [tenantId], references: [id])
  teacher   Teacher         @relation(fields: [teacherId], references: [id])
  session   AcademicSession @relation(fields: [sessionId], references: [id])
  class     AcademicClass   @relation(fields: [classId], references: [id])
  section   Section         @relation(fields: [sectionId], references: [id])

  @@index([tenantId])
  @@index([teacherId])
  @@index([sessionId, classId, sectionId])
  @@map("teacher_schedules")
}

model ExamSchedule {
  id          Int             @id @default(autoincrement())
  tenantId    Int             @map("tenant_id")
  examName    String          @db.VarChar(150)
  sessionId   Int
  classId     Int
  subjectId   Int
  examDate    DateTime
  startTime   String          @db.VarChar(10)
  endTime     String          @db.VarChar(10)
  totalMarks  Int?
  room        String?         @db.VarChar(100)
  invigilator String?         @db.VarChar(150)
  notes       String?         @db.VarChar(255)
  status      String          @default("active") @db.VarChar(50)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  tenant      Tenant          @relation("TenantExamSchedules", fields: [tenantId], references: [id])
  session     AcademicSession @relation(fields: [sessionId], references: [id])
  class       AcademicClass   @relation(fields: [classId], references: [id])
  subject     Subject         @relation(fields: [subjectId], references: [id])

  @@index([tenantId])
  @@index([sessionId, classId, subjectId])
  @@index([examDate, status])
  @@map("exam_schedules")
}

model ResultGrade {
  id          Int      @id @default(autoincrement())
  tenantId    Int      @map("tenant_id")
  title       String   @db.VarChar(150)
  code        String?  @db.VarChar(20)
  fromPercent Int
  toPercent   Int
  status      String   @default("active") @db.VarChar(50)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation("TenantResultGrades", fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([status, fromPercent, toPercent])
  @@map("result_grades")
}

model ExamResult {
  id            Int                 @id @default(autoincrement())
  tenantId      Int                 @map("tenant_id")
  branchId      Int?                @map("branch_id")
  studentId     Int
  sessionId     Int
  classId       Int
  sectionId     Int?
  examName      String              @default("امتحانی رزلٹ") @db.VarChar(150)
  totalMarks    Int
  obtainedMarks Int
  percentage    Decimal             @db.Decimal(5, 2)
  gradeTitle    String?             @db.VarChar(150)
  gradeCode     String?             @db.VarChar(20)
  remarks       String?             @db.VarChar(255)
  status        String              @default("active") @db.VarChar(50)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  tenant        Tenant              @relation("TenantExamResults", fields: [tenantId], references: [id])
  student       Student             @relation(fields: [studentId], references: [id])
  session       AcademicSession     @relation(fields: [sessionId], references: [id])
  class         AcademicClass       @relation(fields: [classId], references: [id])
  section       Section?            @relation(fields: [sectionId], references: [id])
  subjects      ExamResultSubject[]

  @@unique([tenantId, studentId, sessionId, classId, sectionId, examName], map: "exam_results_tenant_student_exam_uq")
  @@index([tenantId])
  @@index([branchId])
  @@index([tenantId, branchId])
  @@index([studentId], map: "exam_results_studentId_fkey_idx")
  @@index([sessionId], map: "exam_results_sessionId_fkey_idx")
  @@index([sessionId, classId, sectionId])
  @@index([status, percentage])
  @@map("exam_results")
}

model ExamResultSubject {
  id            Int        @id @default(autoincrement())
  tenantId      Int        @map("tenant_id")
  examResultId  Int
  subjectId     Int
  totalMarks    Int
  obtainedMarks Int
  percentage    Decimal    @db.Decimal(5, 2)
  gradeTitle    String?    @db.VarChar(150)
  gradeCode     String?    @db.VarChar(20)
  status        String     @default("active") @db.VarChar(50)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  tenant        Tenant     @relation("TenantExamResultSubjects", fields: [tenantId], references: [id])
  examResult    ExamResult @relation(fields: [examResultId], references: [id])
  subject       Subject    @relation(fields: [subjectId], references: [id])

  @@unique([tenantId, examResultId, subjectId], map: "exam_result_subjects_tenant_result_subject_uq")
  @@index([tenantId])
  @@index([examResultId], map: "exam_result_subjects_examResultId_fkey_idx")
  @@index([subjectId])
  @@map("exam_result_subjects")
}

model Student {
  id                 Int                      @id @default(autoincrement())
  tenantId           Int                      @map("tenant_id")
  branchId           Int?                     @map("branch_id")
  admissionNumber    String                   @db.VarChar(100)
  admissionDate      DateTime?
  admissionFee       Decimal?                 @db.Decimal(10, 2)
  fullName           String                   @db.VarChar(150)
  fatherName         String                   @db.VarChar(150)
  gender             String                   @db.VarChar(20)
  caste              String?                  @db.VarChar(100)
  cnic               String?                  @db.VarChar(50)
  dob                DateTime?
  bForm              String?                  @db.VarChar(50)
  phone              String?                  @db.VarChar(50)
  whatsapp           String?                  @db.VarChar(50)
  email              String?                  @db.VarChar(150)
  address            String?                  @db.VarChar(255)
  currentAddress     String?                  @db.VarChar(255)
  permanentAddress   String?                  @db.VarChar(255)
  district           String?                  @db.VarChar(150)
  prevMadrassa       String?                  @db.VarChar(150)
  prevSchool         String?                  @db.VarChar(150)
  secularEdu         String?                  @db.VarChar(150)
  religiousEdu       String?                  @db.VarChar(150)
  requiredClass      String?                  @db.VarChar(150)
  requiredJamaat     String?                  @db.VarChar(150)
  teacherName        String?                  @db.VarChar(150)
  medicalCondition   String?                  @db.VarChar(255)
  monthlyFee         Decimal?                 @db.Decimal(10, 2)
  reside             String?                  @db.VarChar(20)
  imageUrl           String?                  @db.VarChar(255)
  status             String                   @default("active") @db.VarChar(50)
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  parents            StudentParent[]
  assignments        StudentClassAssignment[]
  attendances        StudentAttendance[]
  hifzDailyEntries   HifzDailyEntry[]
  hifzWeeklyEntries  HifzWeeklyEntry[]
  hifzMonthlyEntries HifzMonthlyEntry[]
  hifzSiparaEntries  HifzSiparaEntry[]
  feeVouchers        StudentFeeVoucher[]
  examResults        ExamResult[]
  tenant             Tenant                   @relation("TenantStudents", fields: [tenantId], references: [id])
  branch             Branch?                  @relation("BranchStudents", fields: [branchId], references: [id], onDelete: SetNull)

  @@unique([tenantId, admissionNumber])
  @@index([tenantId])
  @@index([branchId])
  @@index([tenantId, branchId])
  @@map("students")
}

model Parent {
  id           Int             @id @default(autoincrement())
  tenantId     Int             @map("tenant_id")
  branchId     Int?            @map("branch_id")
  fullName     String          @db.VarChar(150)
  familyNumber String?         @db.VarChar(100)
  phone        String?         @db.VarChar(50)
  whatsapp     String?         @db.VarChar(50)
  email        String?         @db.VarChar(150)
  cnic         String?         @db.VarChar(50)
  occupation   String?         @db.VarChar(150)
  address      String?         @db.VarChar(255)
  status       String          @default("active") @db.VarChar(50)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  students     StudentParent[]
  tenant       Tenant          @relation("TenantParents", fields: [tenantId], references: [id])
  branch       Branch?         @relation("BranchParents", fields: [branchId], references: [id], onDelete: SetNull)

  @@unique([tenantId, familyNumber])
  @@index([tenantId])
  @@index([branchId])
  @@index([tenantId, branchId])
  @@map("parents")
}

model StudentParent {
  id           Int      @id @default(autoincrement())
  tenantId     Int      @map("tenant_id")
  studentId    Int
  parentId     Int
  relationship String   @db.VarChar(50)
  isPrimary    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  tenant       Tenant   @relation("TenantStudentParents", fields: [tenantId], references: [id])
  student      Student  @relation(fields: [studentId], references: [id])
  parent       Parent   @relation(fields: [parentId], references: [id])

  @@unique([studentId, parentId, relationship])
  @@index([tenantId])
  @@map("student_parents")
}

model StudentClassAssignment {
  id         Int             @id @default(autoincrement())
  tenantId   Int             @map("tenant_id")
  studentId  Int
  branchId   Int
  classId    Int
  sectionId  Int
  sessionId  Int
  status     String          @default("active") @db.VarChar(50)
  assignedAt DateTime        @default(now())
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  tenant     Tenant          @relation("TenantClassAssignments", fields: [tenantId], references: [id])
  student    Student         @relation(fields: [studentId], references: [id])
  branch     Branch          @relation(fields: [branchId], references: [id])
  class      AcademicClass   @relation(fields: [classId], references: [id])
  section    Section         @relation(fields: [sectionId], references: [id])
  session    AcademicSession @relation(fields: [sessionId], references: [id])

  @@index([tenantId])
  @@map("student_class_assignments")
}

model Teacher {
  id                 Int                      @id @default(autoincrement())
  tenantId           Int                      @map("tenant_id")
  branchId           Int?                     @map("branch_id")
  staffType          String                   @default("teacher") @db.VarChar(50)
  fullName           String                   @db.VarChar(150)
  email              String?                  @db.VarChar(150)
  phone              String?                  @db.VarChar(50)
  cnic               String?                  @db.VarChar(50)
  subject            String?                  @db.VarChar(150)
  qualification      String?                  @db.VarChar(150)
  educationInstitute String?                  @db.VarChar(150)
  educationYear      String?                  @db.VarChar(20)
  specialization     String?                  @db.VarChar(150)
  address            String?                  @db.VarChar(255)
  shiftId            Int?
  imageUrl           String?                  @db.VarChar(255)
  basicSalary        Decimal                  @db.Decimal(10, 2)
  bankName           String?                  @db.VarChar(150)
  accountTitle       String?                  @db.VarChar(150)
  accountNumber      String?                  @db.VarChar(100)
  iban               String?                  @db.VarChar(100)
  jobTitle           String?                  @db.VarChar(150)
  department         String?                  @db.VarChar(150)
  employmentType     String?                  @db.VarChar(100)
  appointmentDate    String?                  @db.VarChar(20)
  joiningDate        String?                  @db.VarChar(20)
  experienceSummary  String?                  @db.VarChar(500)
  notes              String?                  @db.VarChar(500)
  status             String                   @default("active") @db.VarChar(50)
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  attendances        TeacherAttendance[]
  salaryIncrements   TeacherSalaryIncrement[]
  salaryEntries      SalaryEntry[]
  schedules          TeacherSchedule[]
  shift              Shift?                   @relation(fields: [shiftId], references: [id], onDelete: SetNull)
  tenant             Tenant                   @relation("TenantTeachers", fields: [tenantId], references: [id])
  branch             Branch?                  @relation("BranchTeachers", fields: [branchId], references: [id], onDelete: SetNull)

  @@unique([tenantId, phone])
  @@unique([tenantId, cnic])
  @@index([tenantId])
  @@index([branchId])
  @@index([tenantId, branchId])
  @@index([shiftId])
  @@map("teachers")
}

model TeacherSalaryIncrement {
  id              Int      @id @default(autoincrement())
  tenantId        Int      @map("tenant_id")
  teacherId       Int
  previousSalary  Decimal  @db.Decimal(10, 2)
  incrementAmount Decimal  @db.Decimal(10, 2)
  newSalary       Decimal  @db.Decimal(10, 2)
  effectiveDate   String   @db.VarChar(20)
  reason          String?  @db.VarChar(255)
  createdById     Int?
  status          String   @default("active") @db.VarChar(50)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  tenant          Tenant   @relation("TenantTeacherSalaryIncrements", fields: [tenantId], references: [id])
  teacher         Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  createdBy       Admin?   @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([teacherId])
  @@index([effectiveDate])
  @@index([createdById])
  @@map("teacher_salary_increments")
}

model StudentAttendance {
  id        Int           @id @default(autoincrement())
  tenantId  Int           @map("tenant_id")
  studentId Int
  branchId  Int
  classId   Int
  sectionId Int
  date      DateTime
  status    String        @db.VarChar(20)
  remarks   String?       @db.VarChar(255)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  tenant    Tenant        @relation("TenantStudentAttendances", fields: [tenantId], references: [id])
  student   Student       @relation(fields: [studentId], references: [id])
  branch    Branch        @relation(fields: [branchId], references: [id])
  class     AcademicClass @relation(fields: [classId], references: [id])
  section   Section       @relation(fields: [sectionId], references: [id])

  @@unique([studentId, date])
  @@index([tenantId])
  @@index([tenantId, branchId, date])
  @@index([tenantId, branchId, status, date])
  @@map("student_attendance")
}

model TeacherAttendance {
  id        Int      @id @default(autoincrement())
  tenantId  Int      @map("tenant_id")
  teacherId Int
  branchId  Int
  date      DateTime
  status    String   @db.VarChar(20)
  remarks   String?  @db.VarChar(255)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation("TenantTeacherAttendances", fields: [tenantId], references: [id])
  teacher   Teacher  @relation(fields: [teacherId], references: [id])
  branch    Branch   @relation(fields: [branchId], references: [id])

  @@unique([teacherId, date])
  @@index([tenantId])
  @@index([tenantId, branchId, date])
  @@index([tenantId, branchId, status, date])
  @@map("teacher_attendance")
}

model HifzDailyEntry {
