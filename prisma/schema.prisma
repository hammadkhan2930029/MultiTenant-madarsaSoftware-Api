generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Admin {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(150)
  email     String   @unique @db.VarChar(150)
  username  String   @unique @db.VarChar(100)
  password  String   @db.VarChar(255)
  role      String   @default("admin") @db.VarChar(50)
  status    String   @default("active") @db.VarChar(50)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  madrassaProfile MadrassaProfile?
  financialRecords FinancialRecord[]

  @@map("admins")
}

model MadrassaProfile {
  id          Int      @id @default(autoincrement())
  adminId     Int      @unique
  name        String   @db.VarChar(150)
  email       String   @db.VarChar(150)
  phone1      String?  @db.VarChar(50)
  phone2      String?  @db.VarChar(50)
  address     String?  @db.VarChar(255)
  branch      String?  @db.VarChar(150)
  city        String?  @db.VarChar(150)
  familyNoSeq String?  @db.VarChar(100)
  regNo       String?  @db.VarChar(100)
  logoUrl     String?  @db.VarChar(255)
  status      String   @default("active") @db.VarChar(50)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  admin       Admin    @relation(fields: [adminId], references: [id])

  @@map("madrassa_profiles")
}

model City {
  id        Int      @id @default(autoincrement())
  name      String   @unique @db.VarChar(150)
  status    String   @default("active") @db.VarChar(50)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("cities")
}

model Shift {
  id        Int      @id @default(autoincrement())
  name      String   @unique @db.VarChar(150)
  startTime String   @db.VarChar(10)
  endTime   String   @db.VarChar(10)
  type      String   @db.VarChar(50)
  status    String   @default("active") @db.VarChar(50)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("shifts")
}

model Department {
  id        Int      @id @default(autoincrement())
  name      String   @unique @db.VarChar(150)
  code      String?  @unique @db.VarChar(50)
  head      String?  @db.VarChar(150)
  members   Int      @default(0)
  status    String   @default("active") @db.VarChar(50)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("departments")
}

model Qualification {
  id        Int      @id @default(autoincrement())
  title     String   @unique @db.VarChar(150)
  category  String?  @db.VarChar(150)
  level     String?  @db.VarChar(150)
  status    String   @default("active") @db.VarChar(50)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("qualifications")
}

model Subject {
  id        Int      @id @default(autoincrement())
  name      String   @unique @db.VarChar(150)
  detail    String?  @db.VarChar(255)
  status    String   @default("active") @db.VarChar(50)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  examSchedules ExamSchedule[]
  examResultSubjects ExamResultSubject[]

  @@map("subjects")
}

model Branch {
  id        Int             @id @default(autoincrement())
  name      String          @unique @db.VarChar(150)
  code      String?         @unique @db.VarChar(50)
  address   String?         @db.VarChar(255)
  status    String          @default("active") @db.VarChar(50)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  classes   AcademicClass[]
  assignments StudentClassAssignment[]
  studentAttendances StudentAttendance[]
  teacherAttendances TeacherAttendance[]

  @@map("branches")
}

model AcademicClass {
  id        Int       @id @default(autoincrement())
  name      String    @db.VarChar(150)
  branchId  Int
  status    String    @default("active") @db.VarChar(50)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  branch    Branch    @relation(fields: [branchId], references: [id])
  sections  Section[]
  assignments StudentClassAssignment[]
  studentAttendances StudentAttendance[]
  studentSchedules StudentSchedule[]
  teacherSchedules TeacherSchedule[]
  examSchedules ExamSchedule[]
  examResults ExamResult[]

  @@unique([branchId, name])
  @@map("classes")
}

model Section {
  id        Int           @id @default(autoincrement())
  name      String        @db.VarChar(150)
  classId   Int
  status    String        @default("active") @db.VarChar(50)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  class     AcademicClass @relation(fields: [classId], references: [id])
  assignments StudentClassAssignment[]
  studentAttendances StudentAttendance[]
  studentSchedules StudentSchedule[]
  teacherSchedules TeacherSchedule[]
  examResults ExamResult[]

  @@unique([classId, name])
  @@map("sections")
}

model AcademicSession {
  id        Int      @id @default(autoincrement())
  name      String   @unique @db.VarChar(150)
  startDate DateTime
  endDate   DateTime
  status    String   @default("active") @db.VarChar(50)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  assignments StudentClassAssignment[]
  studentSchedules StudentSchedule[]
  teacherSchedules TeacherSchedule[]
  examSchedules ExamSchedule[]
  examResults ExamResult[]

  @@map("sessions")
}

model StudentSchedule {
  id        Int             @id @default(autoincrement())
  sessionId Int
  classId   Int
  sectionId Int
  subjects  Json
  days      Json
  startTime String          @db.VarChar(10)
  endTime   String          @db.VarChar(10)
  status    String          @default("active") @db.VarChar(50)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  session   AcademicSession @relation(fields: [sessionId], references: [id])
  class     AcademicClass   @relation(fields: [classId], references: [id])
  section   Section         @relation(fields: [sectionId], references: [id])

  @@index([sessionId, classId, sectionId])
  @@map("student_schedules")
}

model TeacherSchedule {
  id        Int             @id @default(autoincrement())
  teacherId Int
  sessionId Int
  classId   Int
  sectionId Int
  subjects  Json
  days      Json
  startTime String          @db.VarChar(10)
  endTime   String          @db.VarChar(10)
  status    String          @default("active") @db.VarChar(50)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  teacher   Teacher         @relation(fields: [teacherId], references: [id])
  session   AcademicSession @relation(fields: [sessionId], references: [id])
  class     AcademicClass   @relation(fields: [classId], references: [id])
  section   Section         @relation(fields: [sectionId], references: [id])

  @@index([teacherId])
  @@index([sessionId, classId, sectionId])
  @@map("teacher_schedules")
}

model ExamSchedule {
  id          Int             @id @default(autoincrement())
  examName    String          @db.VarChar(150)
  sessionId   Int
  classId     Int
  subjectId   Int
  examDate    DateTime
  startTime   String          @db.VarChar(10)
  endTime     String          @db.VarChar(10)
  totalMarks  Int?
  room        String?         @db.VarChar(100)
  invigilator String?         @db.VarChar(150)
  notes       String?         @db.VarChar(255)
  status      String          @default("active") @db.VarChar(50)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  session     AcademicSession @relation(fields: [sessionId], references: [id])
  class       AcademicClass   @relation(fields: [classId], references: [id])
  subject     Subject         @relation(fields: [subjectId], references: [id])

  @@index([sessionId, classId, subjectId])
  @@index([examDate, status])
  @@map("exam_schedules")
}

model ResultGrade {
  id          Int      @id @default(autoincrement())
  title       String   @db.VarChar(150)
  code        String?  @db.VarChar(20)
  fromPercent Int
  toPercent   Int
  status      String   @default("active") @db.VarChar(50)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status, fromPercent, toPercent])
  @@map("result_grades")
}

model ExamResult {
  id            Int                 @id @default(autoincrement())
  studentId     Int
  sessionId     Int
  classId       Int
  sectionId     Int?
  examName      String              @default("امتحانی رزلٹ") @db.VarChar(150)
  totalMarks    Int
  obtainedMarks Int
  percentage    Decimal             @db.Decimal(5, 2)
  gradeTitle    String?             @db.VarChar(150)
  gradeCode     String?             @db.VarChar(20)
  remarks       String?             @db.VarChar(255)
  status        String              @default("active") @db.VarChar(50)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  student       Student             @relation(fields: [studentId], references: [id])
  session       AcademicSession     @relation(fields: [sessionId], references: [id])
  class         AcademicClass       @relation(fields: [classId], references: [id])
  section       Section?            @relation(fields: [sectionId], references: [id])
  subjects      ExamResultSubject[]

  @@unique([studentId, sessionId, classId, sectionId, examName])
  @@index([sessionId, classId, sectionId])
  @@index([status, percentage])
  @@map("exam_results")
}

model ExamResultSubject {
  id            Int        @id @default(autoincrement())
  examResultId  Int
  subjectId     Int
  totalMarks    Int
  obtainedMarks Int
  percentage    Decimal    @db.Decimal(5, 2)
  gradeTitle    String?    @db.VarChar(150)
  gradeCode     String?    @db.VarChar(20)
  status        String     @default("active") @db.VarChar(50)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  examResult    ExamResult @relation(fields: [examResultId], references: [id])
  subject       Subject    @relation(fields: [subjectId], references: [id])

  @@unique([examResultId, subjectId])
  @@index([subjectId])
  @@map("exam_result_subjects")
}

model Student {
  id              Int                      @id @default(autoincrement())
  admissionNumber String                   @unique @db.VarChar(100)
  admissionDate   DateTime?
  admissionFee    Decimal?                 @db.Decimal(10, 2)
  fullName        String                   @db.VarChar(150)
  fatherName      String                   @db.VarChar(150)
  gender          String                   @db.VarChar(20)
  caste           String?                  @db.VarChar(100)
  cnic            String?                  @db.VarChar(50)
  dob             DateTime?
  bForm           String?                  @db.VarChar(50)
  phone           String?                  @db.VarChar(50)
  whatsapp        String?                  @db.VarChar(50)
  email           String?                  @db.VarChar(150)
  address         String?                  @db.VarChar(255)
  currentAddress  String?                  @db.VarChar(255)
  permanentAddress String?                 @db.VarChar(255)
  district        String?                  @db.VarChar(150)
  prevMadrassa    String?                  @db.VarChar(150)
  prevSchool      String?                  @db.VarChar(150)
  secularEdu      String?                  @db.VarChar(150)
  religiousEdu    String?                  @db.VarChar(150)
  requiredClass   String?                  @db.VarChar(150)
  requiredJamaat  String?                  @db.VarChar(150)
  teacherName     String?                  @db.VarChar(150)
  medicalCondition String?                 @db.VarChar(255)
  monthlyFee      Decimal?                 @db.Decimal(10, 2)
  reside          String?                  @db.VarChar(20)
  imageUrl        String?                  @db.VarChar(255)
  status          String                   @default("active") @db.VarChar(50)
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  parents         StudentParent[]
  assignments     StudentClassAssignment[]
  attendances     StudentAttendance[]
  hifzDailyEntries HifzDailyEntry[]
  hifzWeeklyEntries HifzWeeklyEntry[]
  hifzMonthlyEntries HifzMonthlyEntry[]
  hifzSiparaEntries HifzSiparaEntry[]
  feeVouchers      StudentFeeVoucher[]
  examResults      ExamResult[]

  @@map("students")
}

model Parent {
  id         Int             @id @default(autoincrement())
  fullName   String          @db.VarChar(150)
  familyNumber String?       @unique @db.VarChar(100)
  phone      String?         @db.VarChar(50)
  email      String?         @db.VarChar(150)
  cnic       String?         @db.VarChar(50)
  occupation String?         @db.VarChar(150)
  address    String?         @db.VarChar(255)
  status     String          @default("active") @db.VarChar(50)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  students   StudentParent[]

  @@map("parents")
}

model StudentParent {
  id           Int      @id @default(autoincrement())
  studentId    Int
  parentId     Int
  relationship String   @db.VarChar(50)
  isPrimary    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  student      Student  @relation(fields: [studentId], references: [id])
  parent       Parent   @relation(fields: [parentId], references: [id])

  @@unique([studentId, parentId, relationship])
  @@map("student_parents")
}

model StudentClassAssignment {
  id         Int             @id @default(autoincrement())
  studentId  Int
  branchId   Int
  classId    Int
  sectionId  Int
  sessionId  Int
  status     String          @default("active") @db.VarChar(50)
  assignedAt DateTime        @default(now())
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  student    Student         @relation(fields: [studentId], references: [id])
  branch     Branch          @relation(fields: [branchId], references: [id])
  class      AcademicClass   @relation(fields: [classId], references: [id])
  section    Section         @relation(fields: [sectionId], references: [id])
  session    AcademicSession @relation(fields: [sessionId], references: [id])

  @@map("student_class_assignments")
}

model Teacher {
  id           Int      @id @default(autoincrement())
  fullName     String   @db.VarChar(150)
  email        String?  @db.VarChar(150)
  phone        String?  @unique @db.VarChar(50)
  cnic         String?  @unique @db.VarChar(50)
  subject      String   @db.VarChar(150)
  qualification String? @db.VarChar(150)
  address      String?  @db.VarChar(255)
  imageUrl     String?  @db.VarChar(255)
  basicSalary  Decimal  @db.Decimal(10, 2)
  status       String   @default("active") @db.VarChar(50)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  attendances  TeacherAttendance[]
  salaryEntries SalaryEntry[]
  schedules    TeacherSchedule[]

  @@map("teachers")
}

model StudentAttendance {
  id        Int           @id @default(autoincrement())
  studentId Int
  branchId  Int
  classId   Int
  sectionId Int
  date      DateTime
  status    String        @db.VarChar(20)
  remarks   String?       @db.VarChar(255)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  student   Student       @relation(fields: [studentId], references: [id])
  branch    Branch        @relation(fields: [branchId], references: [id])
  class     AcademicClass @relation(fields: [classId], references: [id])
  section   Section       @relation(fields: [sectionId], references: [id])

  @@unique([studentId, date])
  @@map("student_attendance")
}

model TeacherAttendance {
  id        Int      @id @default(autoincrement())
  teacherId Int
  branchId  Int
  date      DateTime
  status    String   @db.VarChar(20)
  remarks   String?  @db.VarChar(255)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  teacher   Teacher  @relation(fields: [teacherId], references: [id])
  branch    Branch   @relation(fields: [branchId], references: [id])

  @@unique([teacherId, date])
  @@map("teacher_attendance")
}

model HifzDailyEntry {
  id                Int      @id @default(autoincrement())
  studentId         Int
  date              DateTime
  sabq              String?  @db.VarChar(150)
  sabqListener      String?  @db.VarChar(150)
  sabqMistake       Int?
  sabqAtkann        Int?
  sabaqi            String?  @db.VarChar(150)
  sabaqiMistake     Int?
  sabaqiAtkann      Int?
  manzil            String?  @db.VarChar(150)
  manzilBeforeDetail String? @db.VarChar(150)
  manzilBeforeMistake Int?
  manzilBeforeAtkann Int?
  manzilAfterDetail String? @db.VarChar(150)
  manzilAfterMistake Int?
  manzilAfterAtkann Int?
  lessonDetail      String?  @db.VarChar(255)
  count             Int?
  performanceStatus String   @db.VarChar(50)
  remarks           String?  @db.VarChar(255)
  status            String   @default("active") @db.VarChar(50)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  student           Student  @relation(fields: [studentId], references: [id])

  @@unique([studentId, date])
  @@map("hifz_daily_entries")
}

model HifzWeeklyEntry {
  id                Int      @id @default(autoincrement())
  studentId         Int
  weekLabel         String?  @db.VarChar(150)
  className         String?  @db.VarChar(150)
  sectionName       String?  @db.VarChar(150)
  teacherName       String?  @db.VarChar(150)
  weekStartDate     DateTime
  weekEndDate       DateTime
  siparaFrom        String?  @db.VarChar(100)
  siparaTo          String?  @db.VarChar(100)
  lessonFrom        String?  @db.VarChar(150)
  lessonTo          String?  @db.VarChar(150)
  sawal1            Int?
  sawal2            Int?
  sawal3            Int?
  tahajji           Int?
  panja             Int?
  khudKhwani        Int?
  classWork         String?  @db.VarChar(150)
  performanceStatus String   @db.VarChar(50)
  remarks           String?  @db.VarChar(255)
  status            String   @default("active") @db.VarChar(50)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  student           Student  @relation(fields: [studentId], references: [id])

  @@unique([studentId, weekStartDate, weekEndDate])
  @@map("hifz_weekly_entries")
}

model HifzMonthlyEntry {
  id                Int      @id @default(autoincrement())
  studentId         Int
  month             Int
  year              Int
  startSabq         String?  @db.VarChar(150)
  endSabq           String?  @db.VarChar(150)
  totalRecitation   String?  @db.VarChar(150)
  performanceStatus String   @db.VarChar(50)
  remarks           String?  @db.VarChar(255)
  status            String   @default("active") @db.VarChar(50)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  student           Student  @relation(fields: [studentId], references: [id])

  @@unique([studentId, month, year])
  @@map("hifz_monthly_entries")
}

model HifzSiparaEntry {
  id                Int      @id @default(autoincrement())
  studentId         Int
  siparaNumber      Int
  startDate         DateTime?
  endDate           DateTime?
  totalDays         Int?
  quality           String?  @db.VarChar(150)
  performanceStatus String   @db.VarChar(50)
  remarks           String?  @db.VarChar(255)
  status            String   @default("active") @db.VarChar(50)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  student           Student  @relation(fields: [studentId], references: [id])

  @@unique([studentId, siparaNumber])
  @@map("hifz_sipara_entries")
}

model FinanceHead {
  id              Int              @id @default(autoincrement())
  name            String           @unique @db.VarChar(150)
  type            String           @db.VarChar(20)
  description     String?          @db.VarChar(255)
  status          String           @default("active") @db.VarChar(50)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  salaryEntries   SalaryEntry[]
  transactions    FinanceTransaction[]

  @@map("finance_heads")
}

model StudentFeeVoucher {
  id             Int      @id @default(autoincrement())
  voucherNo      String   @unique @db.VarChar(100)
  studentId      Int
  feeMonth       Int
  feeYear        Int
  monthlyFee     Decimal  @db.Decimal(10, 2)
  admissionFee   Decimal  @default(0) @db.Decimal(10, 2)
  arrears        Decimal  @default(0) @db.Decimal(10, 2)
  discount       Decimal  @default(0) @db.Decimal(10, 2)
  fine           Decimal  @default(0) @db.Decimal(10, 2)
  totalAmount    Decimal  @db.Decimal(10, 2)
  paidAmount     Decimal  @default(0) @db.Decimal(10, 2)
  dueAmount      Decimal  @db.Decimal(10, 2)
  dueDate        DateTime?
  paidDate       DateTime?
  paymentMethod  String?  @db.VarChar(50)
  remarks        String?  @db.VarChar(255)
  status         String   @default("unpaid") @db.VarChar(50)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  student        Student  @relation(fields: [studentId], references: [id])

  @@unique([studentId, feeMonth, feeYear])
  @@index([feeMonth, feeYear, status])
  @@map("student_fee_vouchers")
}

model FundCollection {
  id              Int      @id @default(autoincrement())
  collectionGroupId String @db.VarChar(100)
  donorName       String   @db.VarChar(150)
  careOf          String?  @db.VarChar(150)
  phone           String?  @db.VarChar(50)
  paymentMode     String   @db.VarChar(50)
  donationType    String   @db.VarChar(100)
  donationSubType String   @db.VarChar(100)
  purpose         String?  @db.VarChar(255)
  amount          Decimal  @db.Decimal(10, 2)
  receiptNo       String?  @db.VarChar(100)
  details         String?  @db.VarChar(255)
  paymentDate     DateTime
  remarks         String?  @db.VarChar(255)
  status          String   @default("active") @db.VarChar(50)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([collectionGroupId])
  @@map("fund_collections")
}

model SalaryEntry {
  id            Int         @id @default(autoincrement())
  teacherId      Int
  financeHeadId  Int
  amount         Decimal    @db.Decimal(10, 2)
  salaryMonth    Int
  salaryYear     Int
  paymentDate    DateTime
  remarks        String?    @db.VarChar(255)
  status         String     @default("active") @db.VarChar(50)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  teacher        Teacher    @relation(fields: [teacherId], references: [id])
  financeHead    FinanceHead @relation(fields: [financeHeadId], references: [id])

  @@unique([teacherId, salaryMonth, salaryYear])
  @@map("salary_entries")
}

model FinanceTransaction {
  id              Int         @id @default(autoincrement())
  financeHeadId   Int
  type            String      @db.VarChar(20)
  amount          Decimal     @db.Decimal(10, 2)
  transactionDate DateTime
  paymentMode     String?     @db.VarChar(50)
  paymentStatus   String?     @db.VarChar(50)
  slipNo          String?     @db.VarChar(100)
  details         String?     @db.VarChar(255)
  status          String      @default("active") @db.VarChar(50)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  financeHead     FinanceHead @relation(fields: [financeHeadId], references: [id])

  @@index([type, transactionDate])
  @@index([financeHeadId])
  @@map("finance_transactions")
}

model FinancialRecord {
  id          Int      @id @default(autoincrement())
  type        String   @db.VarChar(20)
  category    String   @db.VarChar(150)
  description String?  @db.VarChar(255)
  amount      Decimal  @db.Decimal(10, 2)
  date        DateTime
  status      String   @default("active") @db.VarChar(50)
  createdById Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   Admin?   @relation(fields: [createdById], references: [id])

  @@index([type, date, status])
  @@index([createdById])
  @@map("financial_records")
}
